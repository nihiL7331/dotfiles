# --- change workspaces (option + number) ---
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5

# --- change focus (option + hjkl) ---
alt - h : yabai -m window --focus west
alt - l : yabai -m window --focus east
alt - k : yabai -m window --focus north
alt - j : yabai -m window --focus south

# --- move apps to workspaces (option + shift + number) ---
alt + shift - 1 : yabai -m window --space 1 --focus
alt + shift - 2 : yabai -m window --space 2 --focus
alt + shift - 3 : yabai -m window --space 3 --focus
alt + shift - 4 : yabai -m window --space 4 --focus
alt + shift - 5 : yabai -m window --space 5 --focus

# --- swap apps (option + shift + hjkl) ---
alt + shift - h : yabai -m window --swap west
alt + shift - l : yabai -m window --swap east
alt + shift - k : yabai -m window --swap north
alt + shift - j : yabai -m window --swap south

# warp windows
ctrl + alt - h : yabai -m window --warp west
ctrl + alt - j : yabai -m window --warp south
ctrl + alt - k : yabai -m window --warp north
ctrl + alt - l : yabai -m window --warp east

# reset all window sizes to equal
alt - 0 : yabai -m space --b

# toggle between floating and tiling for the active window
alt - f : yabai -m window --toggle float --grid 4:4:1:1:2:2alance
